<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    tools:context=".StatisticsFragment">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            style="@style/LabelText"
            android:text="OVERVIEW"
            android:textColor="@color/accent" />

        <TextView
            style="@style/HeaderText"
            android:text="Your Stats"
            android:textSize="32sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingHorizontal="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Total Watched Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@drawable/card_gold_border"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    style="@style/LabelText"
                    android:text="TOTAL WATCHED"
                    android:textColor="@color/accent"
                    android:letterSpacing="0.05"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/statTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0"
                    android:textColor="@color/accent"
                    android:textSize="48sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/SubText"
                    android:text="COMPLETED"
                    android:textColor="@color/accent"
                    android:letterSpacing="0.05"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statWatchingCount"
                        style="@style/SubText"
                        android:text="0 Watching"
                        android:textColor="@color/blue"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="@color/border" />

                    <TextView
                        android:id="@+id/statPlanningCount"
                        style="@style/SubText"
                        android:text="0 Planning"
                        android:textColor="@color/text_sub"
                        android:textSize="13sp" />

                </LinearLayout>
            </LinearLayout>

            <!-- Breakdown Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        style="@style/LabelText"
                        android:text="BREAKDOWN"
                        android:textColor="@color/text_sub"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/pill_background"
                            android:backgroundTint="@color/elevated"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_movie_clapper"
                                app:tint="@color/text_sub"
                                android:contentDescription="Movie Icon" />

                            <TextView
                                android:id="@+id/statMoviesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="0"
                                android:textColor="@color/blue"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/SubText"
                                android:text="Movies" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/pill_background"
                            android:backgroundTint="@color/elevated"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_tv_show"
                                app:tint="@color/text_sub"
                                android:contentDescription="TV Icon" />

                            <TextView
                                android:id="@+id/statSeriesCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="0"
                                android:textColor="@color/green"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                style="@style/SubText"
                                android:text="Series" />
                        </LinearLayout>
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/statProgress"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:layout_marginTop="20dp"
                        android:max="100"
                        android:progress="50"
                        android:progressDrawable="@drawable/stat_progress_drawable" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">

                        <TextView
                            android:id="@+id/txtMoviePercent"
                            style="@style/SubText"
                            android:layout_alignParentStart="true"
                            android:text="Movies 0%"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/txtSeriesPercent"
                            style="@style/SubText"
                            android:layout_alignParentEnd="true"
                            android:text="Series 0%"
                            android:textSize="11sp" />
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Average Rating Hero -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/card"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        style="@style/LabelText"
                        android:text="AVERAGE RATING"
                        android:textColor="@color/text_muted" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/statAvgRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/accent"
                            android:textSize="48sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="24dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/statStars"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.1"
                                android:text="☆☆☆☆☆"
                                android:textColor="@color/accent"
                                android:textSize="24sp" />

                            <TextView
                                style="@style/SubText"
                                android:layout_marginTop="4dp"
                                android:text="across all titles"
                                android:textSize="14sp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Recently Added Section -->
            <TextView
                style="@style/LabelText"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="RECENTLY ADDED"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentlyAdded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_recent" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>